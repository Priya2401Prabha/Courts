<?xml version="1.0" ?>
<odoo>

    <!-- TREE VIEW -->

    <record id="view_product_report_tree_afg" model="ir.ui.view">
        <field name="name">product.report.afg.tree</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">

            <list string="Product Analysis" create="0">
                <header>
                    <button name="action_open_sales_popup"
                            string="Update Sale Values"
                            type="object"
                            class="btn-primary"/>
                </header>
                <field name="default_code" string="Product Code" optional="show"/>
                <field name="name" string="Product Description" optional="show"/>
                <field name="default_vendor_id" string="Vendor" optional="show"/>
                <field name="brand_name" optional="show"/>
                <field name="categ_id" optional="show"/>
                <field name="qty_available" string="Stock Unit" optional="show"/>
                <field name="onhand_valuation_value" string="Stock Value" optional="show"/>
                <field name="weekly_valuation" string="Weekly Transfer Value" column_invisible="1" optional="show"/>
                <field name="weekly_valuation_new" string="Weekly Transfer Value" optional="show"/>
                <field name="weekly_quantity" string="Week Transfer unit" optional="show"/>
                <field name="weekly_sold_units" string="Week Sale unit" optional="show"/>
                <field name="weekly_sold_value" string="Week Sale Value" optional="show"/>
                <field name="sales_count" string="Total sale count" optional="show"/>
                <field name="year_sold_units" string="YTD Sale unit" optional="show"/>
                <field name="year_sold_value" string="YTD Sale Value" optional="show"/>
                <field name="os_po_qty" string="O/S PO qty" optional="show"/>
                <field name="os_po_value" string="O/S PO Value" optional="show"/>
                <field name="standard_price" string="Cost Price" optional="show"/>
                <field name="list_price" string="Retail Price" optional="show"/>

            </list>

        </field>
    </record>
    <record id="afg_purchase_list" model="ir.ui.view">
        <field name="name">purchase.order.tree.inherit</field>
        <field name="model">purchase.order.line</field>
        <field name="priority">4</field>
        <field name="inherit_id" ref="purchase.purchase_history_tree"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='product_uom_qty']" position="after">
                    <field name="os_po_qty_new" sum="Total Outstanding Quantities"/>
                    <field name="os_po_value" sum="Sum of Outstanding Po Value"/>

            </xpath>
        </field>
    </record>
        <record id="view_purchase_order_form_inherit_conversion" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.conversion</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">

            <!-- Add fields inside order line tree -->
            <xpath expr="//field[@name='order_line']/list/field[@name='price_unit']" position="before">
                <field name="converted_qty" readonly="1"/>
                <field name="conversion_uom" readonly="1"/>
            </xpath>

            <!-- Also add in form view of order line (popup) -->
            <xpath expr="//field[@name='order_line']/form//field[@name='price_unit']" position="before">
                <field name="conversion_uom" readonly="1"/>
                <field name="converted_qty" readonly="1"/>
            </xpath>

        </field>
    </record>

    <record id="afg_stock_location_usage_form" model="ir.ui.view">
        <field name="name">stock.location.form.inherit</field>
        <field name="model">stock.location</field>
        <field name="priority">4</field>
        <field name="inherit_id" ref="stock.view_location_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='usage']" position="after">
                    <field name="is_usage_location"/>

            </xpath>
        </field>
    </record>

    <record id="afg_stock_move_line_list" model="ir.ui.view">
        <field name="name">stock.move.tree.inherit</field>
        <field name="model">stock.move.line</field>
        <field name="priority">4</field>
        <field name="inherit_id" ref="stock.view_move_line_tree"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='quantity']" position="after">
                    <field name="valuation_value" sum="Total Value"/>
                    <field name="is_usage_location" optional="hide"/>

<!--                    <field name="os_po_value" sum="Sum of Outstanding Po Value"/>-->

            </xpath>
        </field>
    </record>

<!--    purchase.purchase_history_tree-->
    <record id="view_product_sales_popup" model="ir.ui.view">
        <field name="name">product.sales.popup</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <form string="Product sale Period" help="By default from date calculated based on today's date">
                <group>
                    <field name="from_date"/>
                    <field name="to_date"/>
                </group>

                <footer>
                    <button name="update_compute_sales"
                            type="object"
                            string="Update Values"
                            class="btn-primary"/>

                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="sale.action_order_report_products" model="ir.actions.act_window">
        <field name="view_mode">list</field>
    </record>
    <record id="action_product_report_afg" model="ir.actions.act_window">
        <field name="name">Product Analysis</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_product_report_tree_afg"/>
    </record>


    <!-- MENU -->

    <menuitem
            id="menu_product_report_root_afg"
            name="Product"
            parent="stock.menu_warehouse_report"
            sequence="90"
            action="action_product_report_afg"/>


</odoo>