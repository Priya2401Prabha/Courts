<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="message_wizard_form" model="ir.ui.view">
        <field name="name">message.wizard.form</field>
        <field name="model">message.wizard</field>
        <field name="arch" type="xml">
            <form string="Message">
                <sheet>
                    <group>
                        <field name="message"/>
                    </group>
                </sheet>
                <footer>
                    <!-- Simple OK button to close the wizard -->
                    <button string="Ok" class="btn btn-secondary" special="cancel"/>
                    <!-- Uncomment below if you want to call action_ok instead -->
                    <!-- <button name="action_ok" string="Ok" type="object" class="oe_highlight"/> -->
                </footer>
            </form>
        </field>
    </record>
</odoo>
