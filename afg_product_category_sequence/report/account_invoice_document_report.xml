                            <br/>
                        </t>
                        <t t-if="o.partner_id.country_id.name">
                            <span style="padding-left:24px;" t-field="o.partner_id.country_id.name"/>
                            <br/>
                        </t>
                        <t t-if="o.partner_id.vat">
                            <span style="padding-left:24px;">VAT:</span>
                            <span t-field="o.partner_id.vat"/>
                            <br/>
                        </t>
                        <t t-if="o.partner_id.ref">
                            <span style="padding-left:24px;">BRN:</span>
                            <span t-field="o.partner_id.ref"/>
                        </t>
                    </t>
                </div>
                <div class="col-6">
                </div>
            </div>

        </xpath>
        <xpath t-if="o.company_id.name == 'IMF'" expr="//div[contains(@id,'information')]" position="replace"/>

        <xpath expr="//p[contains(@name,'payment_communication')]" position="replace">
