            <!--</div>-->

            <table class="table table-borderless" t-if="o.company_id.name == 'IMF'">
                <tbody>
                    <tr>
                        <td t-if="o and o._name == 'account.move' and o.move_type == 'out_invoice'and o.company_id.name == 'IMF'"
                            class="text-center" style="font-weight:bold;" colspan="2">
                            <h4 style="font-weight:bold;">VAT Invoice: #
                                <span t-if="o.name and o.name != '/'" t-field="o.name">INV/2023/0001</span>
                            </h4>
                        </td>
                    </tr>
                    <tr>
                        <td style="width=50%;">
                            <t>
                                <strong>Customer Address:</strong>
                                <br/>
                            </t>
                            <t t-if="o.partner_id.name">
                                <span t-field="o.partner_id.name"/>
                                <br/>
                            </t>
                            <t t-if="o.partner_id.street">
                                <span t-field="o.partner_id.street"/>
                                <br/>
                            </t>
                            <t t-if="o.partner_id.street2">
                                <span t-field="o.partner_id.street2"/>
                                <br/>
                            </t>
                            <t t-if="o.partner_id.city">
                                <span t-field="o.partner_id.city"/>
                                <br/>
                            </t>
                            <t t-if="o.partner_id.country_id.name">
                                <span t-field="o.partner_id.country_id.name"/>
                                <br/>
                            </t>
                            <t t-if="o.partner_id.vat">
                                <span>VAT:</span>
                                <span t-field="o.partner_id.vat"/>
                                <br/>
                            </t>
                            <t t-if="o.partner_id.ref">
                                <span>BRN:</span>
                                <span t-field="o.partner_id.ref"/>
                            </t>

                        </td>
                        <td style="padding-left:50px;">
                            <div t-if="o.invoice_date" name="invoice_date">
                                <!--<t t-if="o.move_type == 'out_invoice'"><strong>Invoice Date</strong></t>-->
                                <!--<t t-elif="o.move_type == 'out_refund'"><strong>Credit Note Date</strong></t>-->
                                <!--<t t-elif="o.move_type == 'out_receipt'"><strong>Receipt Date</strong></t>-->
                                <!--<t t-else=""></t>-->
                                <strong>Date</strong>:
                                <span t-field="o.invoice_date">2023-09-12</span>
                            </div>
                            <div t-if="o.ref" name="reference">
                                <strong>Reference</strong>:
                                <span t-field="o.ref">INV/2023/00001</span>
                            </div>
                            <div t-if="o.invoice_origin" name="origin">
                                <strong>Source</strong>:
                                <span t-field="o.invoice_origin">SO123</span>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>


            <div class="row" t-if="o.company_id.name != 'IMF'">
                <div class="col-6">
                    <t t-set="address">
                        <!--Customer Address -->
                        <t t-if="o.partner_id.name">
                            <span style="padding-left:24px;" t-field="o.partner_id.name"/>
                            <br/>
                        </t>
                        <t t-if="o.partner_id.street">
                            <span style="padding-left:24px;" t-field="o.partner_id.street"/>
                            <br/>
                        </t>
                        <t t-if="o.partner_id.street2">
