<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_delivery_document_afg" inherit_id="stock.report_delivery_document">
        <!--        <xpath expr="//div[hasclass('page')]" position="before">-->
        <!--            <style>-->
        <!--                .my-bold-text-->
        <!--                {-->
        <!--                    font-weight: bold !important; /* !important can help with specificity issues */-->
        <!--                }-->
        <!--            </style>-->
        <!--        </xpath>-->
        <!-- ================= HEADER CUSTOMIZATION ================= -->
        <xpath expr="//t[@t-set='address']" position="before">

            <table class="table table-borderless">
                <tbody>
                    <tr>
                        <td style="width=50%;">
                            <span>Ship From:</span>
                        </td>
                        <td style="width=50%;" colspan="2">
                            <span t-esc="o.location_id.warehouse_id.name"/>
                        </td>
                    </tr>

                    <tr>
                        <td style="width=30%;">
                            <span>Ship To:</span>
                        </td>
                        <td style="width=45%;">
                            <div t-esc="partner"
                                 t-options="{                                     &quot;widget&quot;: &quot;contact&quot;,                                     &quot;fields&quot;: [&quot;address&quot;, &quot;name&quot;, &quot;phone&quot;],                                     &quot;no_marker&quot;: True                                  }"/>
                        </td>

                        <td style="width=45%;">
                            DN:
                            <span t-field="o.name"/>
                            <br/>
                            Order No:
                            <span t-field="o.origin"/>
                            <br/>
                            Shipping Date:
                            <span t-field="o.scheduled_date"/>
                        </td>
                    </tr>

                </tbody>
            </table>
        </xpath>

        <!-- Remove Default Header Sections -->
        <xpath expr="//t[@t-set='information_block']" position="replace"/>
        <xpath expr="//div[@id='informations']" position="replace"/>
        <xpath expr="//div[@name='outgoing_warehouse_address']" position="replace"/>
        <xpath expr="//div[@name='outgoing_delivery_address']" position="replace"/>
        <!--        <xpath expr="//div[@name='div_sched_date']" position="replace"/>-->

        <!-- ================= TITLE ================= -->
        <xpath expr="//div[hasclass('page')]/h2" position="replace">
            <h2 class="text-center" style="font-weight:bold;">
                <b>DELIVERY NOTE</b>
            </h2>
        </xpath>
        <!-- ================= TABLE WHEN NOT DONE ================= -->
        <xpath expr="//div[hasclass('page')]/table[@name='stock_move_table']" position="replace">

            <table class="table table-borderless" t-if="o.state != 'done'" name="stock_move_table">
                <style>
                    table[name="stock_move_table"] {
                    border-collapse: collapse;
                    width:100%;
                    }

                    table[name="stock_move_table"] thead th {
                    border-bottom: 1px solid #DEE2E6;
                    border-top: 1px solid #DEE2E6;
                    }

                    table[name="stock_move_table"] tbody tr {
                    border-bottom: 1px solid #DEE2E6;
                    }

                    table[name="stock_move_table"] tbody tr:last-child {
                    border-bottom: none;
                    }
                </style>


                <t t-set="has_barcode"
                   t-value="any(move.product_id and move.product_id.barcode for move in o.move_ids_without_package)"/>

                <t t-set="has_serial_number"
                   t-value="any(move_line.lot_id or move_line.lot_name for move_line in o.move_line_ids)"
                   groups="stock.group_production_lot"/>

                <thead>

                    <tr style="font-weight:bold;">
                        <th style="font-weight:bold;">#</th>

                        <th style="font-weight:bold;" t-if="has_barcode">
                            Item Code
                        </th>

                        <th style="font-weight:bold;">
                            Description
                        </th>

                        <t t-if="has_serial_number">
                            <th style="font-weight:bold;">Lot/Serial Number</th>
                        </t>

                        <th style="font-weight:bold;">
                            Qty Requested
                        </th>
                        <th style="font-weight:bold;">
                            Qty Shipped
                        </th>
                        <th style="font-weight:bold;">
                            Qty Received
                        </th>
                    </tr>
                </thead>

                <tbody>
                    <t t-set="row_index" t-value="1"/>

                    <t t-foreach="o.move_ids_without_package" t-as="move">
                        <t t-foreach="move.move_line_ids.sorted(key=lambda ml: ml.location_id.id)" t-as="ml">

                            <tr>

                                <td>
                                    <t t-esc="row_index"/>
                                </td>

                                <td t-if="has_barcode">
                                    <span t-field="move.product_id.barcode"/>
                                </td>

                                <td>
                                    <span t-field="move.product_id.display_name"/>
                                    <br/>
                                    <span t-field="move.product_id.description_picking"/>
                                </td>

                                <td t-if="has_serial_number">
                                    <span t-field="ml.lot_id.name"/>
                                </td>

                                <td>
                                    <span t-field="move.product_uom_qty"/>
                                    <span t-field="move.product_uom" groups="uom.group_uom"/>
                                </td>

                                <td>
                                    <span t-if="o.state == 'done'" t-field="ml.move_id.quantity"/>
                                    <span t-if="o.state == 'done'" t-field="ml.product_uom_id" groups="uom.group_uom"/>
                                </td>

                                <td/>

                            </tr>

                            <t t-set="row_index" t-value="row_index + 1"/>

                        </t>
                    </t>
                </tbody>

            </table>

        </xpath>


        <!-- ================= TABLE WHEN DONE ================= -->
        <xpath expr="//div[hasclass('page')]/table[@name='stock_move_line_table']" position="replace">

            <table class="table table-borderless" t-if="o.move_line_ids and o.state == 'done'"
                   name="stock_move_line_table">
                <style>
                    table[name="stock_move_line_table"] {
                    border-collapse: collapse;
                    width:100%;
                    }

                    table[name="stock_move_line_table"] thead th {
                    border-bottom: 1px solid #DEE2E6;
                    border-top: 1px solid #DEE2E6;
                    }

                    table[name="stock_move_line_table"] tbody tr {
                    border-bottom: 1px solid #DEE2E6;
                    }

                    table[name="stock_move_line_table"] tbody tr:last-child {
                    border-bottom: none;
                    }
                </style>

                <t t-set="has_barcode"
                   t-value="any(move_line.product_id and move_line.product_id.barcode                    for move_line in o.move_line_ids)"/>

                <t t-set="has_serial_number"
                   t-value="any(move_line.lot_id or move_line.lot_name                    for move_line in o.move_line_ids)"
                   groups="stock.group_production_lot"/>

                <thead>
                    <tr>
                        <th style="font-weight:bold;">#</th>

                        <th style="font-weight:bold;" t-if="has_barcode">
                            Item Code
                        </th>

                        <th style="font-weight:bold;">
                            Description
                        </th>

                        <t t-if="has_serial_number">
                            <th style="font-weight:bold;">Lot/Serial Number</th>
                        </t>

                        <th style="font-weight:bold;">
                            Qty Requested
                        </th>
                        <th style="font-weight:bold;">
                            Qty Shipped
                        </th>
                        <th style="font-weight:bold;">
                            Qty Received
                        </th>
                    </tr>
                </thead>

                <tbody>

                    <t t-set="row_index" t-value="1"/>

                    <t t-foreach="o.move_ids_without_package" t-as="move">
                        <t t-foreach="move.move_line_ids.sorted(key=lambda ml: ml.location_id.id)" t-as="ml">

                            <tr>
                                <td>
                                    <t t-esc="row_index"/>
                                </td>

                                <td t-if="has_barcode">
                                    <span t-field="move.product_id.barcode"/>
                                </td>

                                <td>
                                    <span t-field="ml.product_id.display_name"/>
                                    <br/>
                                    <span t-field="ml.product_id.description_picking"/>
                                </td>

                                <td t-if="has_serial_number">
                                    <span t-field="ml.lot_id.name"/>
                                </td>

                                <td>
                                    <span t-field="move.product_uom_qty"/>
                                    <span t-field="move.product_uom" groups="uom.group_uom"/>
                                </td>

                                <td>
                                    <span t-if="o.state == 'done'" t-field="ml.quantity"/>
                                    <span t-if="o.state == 'done'" t-field="ml.product_uom_id" groups="uom.group_uom"/>
                                </td>

                                <td/>

                            </tr>

                            <t t-set="row_index" t-value="row_index + 1"/>

                        </t>
                    </t>

                </tbody>

            </table>

        </xpath>

    </template>

</odoo>